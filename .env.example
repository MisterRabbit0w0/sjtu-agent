# 复制此文件为 .env 并填入真实信息（.env 已在 .gitignore 中，不会被提交）

JACCOUNT_USERNAME=your_student_id
JACCOUNT_PASSWORD=your_password

# ── 致远一号 API（推荐，交大官方 OpenAI 兼容接口）───────────────────────────
# 填入后将优先使用致远一号，无需再写 agent_config.json
# Base URL 默认为 https://models.sjtu.edu.cn/api/v1，留空即可
# 可用模型：deepseek-chat、deepseek-reasoner、glm-5、minimax、qwen3coder、qwen3vl
ZHIYUAN_API_KEY=your-zhiyuan-api-key
# ZHIYUAN_BASE_URL=https://models.sjtu.edu.cn/api/v1

# ── 其他大模型（可选，若未填 ZHIYUAN_API_KEY 则从 agent_config.json 读取）───
# 可选：填入后验证码将由 Claude Haiku 自动识别，否则需要手动输入
ANTHROPIC_API_KEY=sk-ant-...
